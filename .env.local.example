# Firebase Configuration
# Lấy thông tin này từ Firebase Console > Project Settings > Your apps > Firebase SDK snippet
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key-here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Firebase Admin (bắt buộc trên server cho session và rate-limit bảo mật)
# Có thể dùng một JSON service account trên một dòng:
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Hoặc dùng ba biến riêng bên dưới thay cho JSON:
# FIREBASE_ADMIN_PROJECT_ID=your-project-id
# FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Wholesale Firebase (project/database and Storage isolated from retail)
NEXT_PUBLIC_WHOLESALE_FIREBASE_API_KEY=your-wholesale-api-key
NEXT_PUBLIC_WHOLESALE_FIREBASE_AUTH_DOMAIN=your-wholesale-project.firebaseapp.com
NEXT_PUBLIC_WHOLESALE_FIREBASE_PROJECT_ID=your-wholesale-project
NEXT_PUBLIC_WHOLESALE_FIREBASE_STORAGE_BUCKET=your-wholesale-project.appspot.com
NEXT_PUBLIC_WHOLESALE_FIREBASE_MESSAGING_SENDER_ID=your-wholesale-sender-id
NEXT_PUBLIC_WHOLESALE_FIREBASE_APP_ID=your-wholesale-app-id
WHOLESALE_FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# WHOLESALE_FIREBASE_ADMIN_PROJECT_ID=your-wholesale-project
# WHOLESALE_FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxx@your-wholesale-project.iam.gserviceaccount.com
# WHOLESALE_FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Dùng để HMAC địa chỉ IP và khóa rate-limit; đặt chuỗi ngẫu nhiên >= 32 ký tự.
AUTH_HASH_SECRET=replace-with-at-least-32-random-characters

# Cloudflare Turnstile (challenge chỉ hiện khi vượt ngưỡng rủi ro)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Passkey / WebAuthn. Origin phải khớp chính xác domain production (không có path).
PASSKEY_ORIGIN=https://your-domain.com
PASSKEY_RP_ID=your-domain.com
PASSKEY_RP_NAME=Bakery

# Cloudinary Uploads
# Dùng cho form admin tải ảnh sản phẩm trực tiếp lên Cloudinary.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Public URL (QUAN TRỌNG cho Production!)
# URL công khai của ứng dụng, dùng cho magic links, email, SMS
# Local dev: http://localhost:3000
# Production: https://your-domain.com (hoặc Railway URL)
NEXT_PUBLIC_CUSTOMER_APP_URL=http://localhost:3000

# Zalo OAuth (Optional - cho đăng nhập Zalo)
ZALO_APP_ID=your-zalo-app-id
ZALO_APP_SECRET=your-zalo-app-secret
ZALO_REDIRECT_URI=https://your-domain.com/auth/zalo/callback

# Zalo OA (Optional - cho gửi tin nhắn Zalo)
ZALO_OA_ACCESS_TOKEN=your-zalo-oa-token

# PayOS (QR/Chuyển khoản (Optional)
# Lấy thông tin này từ https://my.payos.vn
PAYOS_CLIENT_ID=your-payos-client-id
PAYOS_API_KEY=your-payos-api-key
PAYOS_CHECKSUM_KEY=your-payos-checksum-key

# Hướng dẫn:
# 1. Copy file này thành .env.local
# 2. Thay thế các giá trị "your-xxx-here" bằng thông tin thực từ Firebase Console
# 3. File .env.local sẽ tự động bị ignore bởi git
# 4. Trên Railway/Production, set các biến môi trường này trong dashboard
# Admin access (required in production)
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-characters
# Optional multi-account RBAC. ADMIN_PASSWORD remains the Owner fallback.
# ADMIN_ACCOUNTS_JSON=[{"id":"marketing-1","name":"Marketing","role":"marketing","password":"replace-me"}]

# OpenAI - trợ lý cấu hình voucher trong trang quản trị
OPENAI_API_KEY=sk-proj-replace-with-your-key
# Có thể đổi model mà không cần sửa code
OPENAI_VOUCHER_MODEL=gpt-5.6-terra
# Cho phép chế độ Chuyên sâu và Auto nâng lên Sol. Đặt false để khóa chi phí.
OPENAI_VOUCHER_ALLOW_SOL=true

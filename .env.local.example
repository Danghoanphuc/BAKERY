# Firebase Configuration
# Lấy thông tin này từ Firebase Console > Project Settings > Your apps > Firebase SDK snippet
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key-here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Cloudinary Uploads
# Dùng cho form admin tải ảnh sản phẩm trực tiếp lên Cloudinary.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Public URL (QUAN TRỌNG cho Production!)
# URL công khai của ứng dụng, dùng cho magic links, email, SMS
# Local dev: http://localhost:3000
# Production: https://your-domain.com (hoặc Railway URL)
NEXT_PUBLIC_CUSTOMER_APP_URL=http://localhost:3000

# Zalo OAuth (Optional - cho đăng nhập Zalo)
ZALO_APP_ID=your-zalo-app-id
ZALO_APP_SECRET=your-zalo-app-secret
ZALO_REDIRECT_URI=https://your-domain.com/auth/zalo/callback

# Zalo OA (Optional - cho gửi tin nhắn Zalo)
ZALO_OA_ACCESS_TOKEN=your-zalo-oa-token

# PayOS (QR/Chuyển khoản (Optional)
# Lấy thông tin này từ https://my.payos.vn
PAYOS_CLIENT_ID=your-payos-client-id
PAYOS_API_KEY=your-payos-api-key
PAYOS_CHECKSUM_KEY=your-payos-checksum-key

# Hướng dẫn:
# 1. Copy file này thành .env.local
# 2. Thay thế các giá trị "your-xxx-here" bằng thông tin thực từ Firebase Console
# 3. File .env.local sẽ tự động bị ignore bởi git
# 4. Trên Railway/Production, set các biến môi trường này trong dashboard
# Admin access (required in production)
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-characters
